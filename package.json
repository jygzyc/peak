{
  "name": "@jygzyc/decx-agent",
  "version": "0.1.0",
  "description": "Standalone configured agent runtime",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "bin": {
    "decx-agent": "dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist dist-packages",
    "build": "npm run clean && tsc && npm run copy-assets",
    "copy-assets": "cp src/server/dashboard.html dist/server/dashboard.html",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.ts",
    "smoke": "node scripts/smoke.mjs",
    "pack": "node scripts/pack.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/openai": "^3.0.73",
    "ai": "^6.0.208",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "GPL-3.0"
}
