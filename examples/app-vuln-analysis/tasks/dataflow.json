{
  "task": {
    "name": "Android fixture WebView dataflow analysis",
    "session": "app-dataflow",
    "target": "DeepLinkActivity WebView and TokenBridge",
    "goal": "Prove or reject an attacker-controlled page to native token disclosure path in the authorized fixture",
    "workspace": "../fixture"
  },
  "profiles": {
    "planner": {
      "role": "planner",
      "runtime": { "worker": "codex" },
      "prompt": {
        "file": "builtin:planner",
        "knowledge": ["../knowledge/android-app-vuln.md"],
        "rules": ["../rules/evidence-gate.md"],
        "skills": ["../skills/android-static-analysis.md"],
        "instructions": "Trace WebView loadUrl, JavaScript enablement and TokenBridge impact. Keep reachability-dependent conclusions pending until evaluated entrypoint broadcast evidence arrives."
      },
      "context": { "graphView": "full", "maxFacts": 60 }
    },
    "explorer": {
      "role": "explorer",
      "runtime": { "worker": "codex" },
      "prompt": {
        "file": "builtin:explorer",
        "knowledge": ["../knowledge/android-app-vuln.md"],
        "rules": ["../rules/evidence-gate.md"],
        "skills": ["../skills/android-static-analysis.md"],
        "instructions": "Trace the url value to WebView.loadUrl and the exposed bridge to SharedPreferences token data."
      },
      "context": { "graphView": "focused", "maxFacts": 40 }
    },
    "evaluator": {
      "role": "evaluator",
      "runtime": { "worker": "codex" },
      "prompt": {
        "file": "builtin:evaluator",
        "rules": ["../rules/evidence-gate.md"],
        "knowledge": ["../knowledge/android-app-vuln.md"]
      },
      "context": { "graphView": "evidence-only", "maxFacts": 60 }
    },
    "metacog": {
      "role": "metacog",
      "runtime": { "worker": "codex" },
      "prompt": {
        "file": "builtin:metacog",
        "rules": ["../rules/evidence-gate.md"],
        "knowledge": ["../knowledge/android-app-vuln.md"]
      },
      "context": { "graphView": "summary", "maxFacts": 80 },
      "triggers": { "everySteps": 5, "stagnationLevel": 3, "everySeconds": 30 }
    }
  },
  "workers": {
    "codex": { "kind": "agent", "backend": "codex", "timeoutMs": 300000 }
  },
  "scheduler": { "maxConcurrent": 2, "refillPerTick": 2, "workerLeaseMs": 300000 },
  "control": { "mainProfile": "planner", "metacogProfile": "metacog", "globalMaxConcurrent": 2 },
  "federation": {
    "scope": "app-vuln-demo",
    "members": ["app-entrypoints", "app-dataflow"]
  }
}
